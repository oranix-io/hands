{
  "name": "quiver",
  "private": true,
  "version": "0.1.0",
  "description": "Ship Android builds, releases, and share links from one place — Cloudflare-native (Workers + Container + D1 + R2).",
  "license": "MIT",
  "type": "module",
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "lint": "pnpm -r lint",
    "lint:fix": "pnpm -r lint:fix",
    "dev:worker": "pnpm --filter @oranix/quiver-worker dev",
    "dev:admin": "pnpm --filter @oranix/quiver-admin dev",
    "deploy:worker": "pnpm --filter @oranix/quiver-worker run deploy",
    "deploy:admin": "pnpm --filter @oranix/quiver-admin run deploy",
    "db:migrate:local": "pnpm --filter @oranix/quiver-worker db:migrate:local",
    "db:migrate:remote": "pnpm --filter @oranix/quiver-worker db:migrate:remote"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "typescript": "^5.7.2"
  }
}
